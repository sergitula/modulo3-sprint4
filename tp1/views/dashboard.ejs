<section class="bg-white p-8 flex flex-col items-center">
    <div class="w-full max-w-[99%] flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold text-sky-700">Lista de Superhéroes</h1>
        <a href="/">
            <button class="rounded-md px-4 py-2 bg-blue-400 font-semibold text-sky-900 shadow-md shadow-gray-500 hover:bg-blue-500 transition-colors"> 
                Volver 
            </button>
        </a>
    </div>

    <div class="w-full max-w-[99%] overflow-x-auto bg-white rounded-lg shadow-md">
        <table class="w-full min-w-[1000px] border border-gray-200 border-collapse">
            <thead>
                <tr class="border-b-2 border-sky-200 bg-blue-400">
                    <th class="p-3 text-left text-sky-900">Superhéroe</th>
                    <th class="p-3 text-left text-sky-900">Nombre Real</th>
                    <th class="p-3 text-left text-sky-900">Edad</th>
                    <th class="p-3 text-left text-sky-900">Origen</th>
                    <th class="p-3 text-left text-sky-900">Poderes</th>
                    <th class="p-3 text-left text-sky-900">Debilidad/es</th>
                    <th class="p-3 text-left text-sky-900">Aliados</th>
                    <th class="p-3 text-left text-sky-900">Enemigos</th>
                    <th class="p-3 text-center text-sky-900 sticky right-0 bg-blue-400">Acciones</th> </tr>
            </thead>
            <tbody>
                <% superheroes.forEach(superheroe => { %>
                    <tr class="border-b border-sky-50 hover:bg-sky-100 transition-colors">
                        <td class="p-3 font-medium"><%= superheroe.nombreSuperHeroe %></td>
                        <td class="p-3 text-gray-600"><%= superheroe.nombreReal %></td>
                        <td class="p-3 text-gray-600"><%= superheroe.edad %></td>
                        <td class="p-3 text-gray-600"><%= superheroe.planetaOrigen %></td>
                        
                        <td class="p-3 text-gray-600 min-w-[200px] max-w-[250px] break-words whitespace-normal"><%= superheroe.poderes %></td>
                        <td class="p-3 text-gray-600 min-w-[150px] max-w-[200px] break-words whitespace-normal"><%= superheroe.debilidad %></td>
                        <td class="p-3 text-gray-600 min-w-[150px] max-w-[200px] break-words whitespace-normal"><%= superheroe.aliados %></td>
                        <td class="p-3 text-gray-600 min-w-[150px] max-w-[200px] break-words whitespace-normal"><%= superheroe.enemigos %></td>
                        
                        <td class="p-3 flex justify-center gap-4 bg-inherit sticky right-0">
                            <a href="/dashboard/editar/<%= superheroe.id %>">
                                <button class="text-sky-600 font-semibold hover:text-sky-800 hover:underline cursor-pointer">Editar</button>
                            </a>
                            <button class="text-red-500 font-semibold hover:text-red-700 hover:underline cursor-pointer" onclick="eliminar('<%= superheroe.id %>', '<%= superheroe.nombreSuperHeroe %>')">Eliminar</button>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</section>
    
<script>
    async function eliminar(id,nombre){
        const confirmar = confirm("¿Seguro de eliminar a '"+nombre+"'?");
        if(!confirmar) return;
        const res = await fetch("api/heroes/" + id, {method: "DELETE"});
        if(res.ok){
            window.location.reload();
        }else{
            alert("Error al eliminar el registro") + (error.message || JSON.stringify(error))
        }
    } 
</script>
